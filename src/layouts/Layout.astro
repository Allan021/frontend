---
import '../styles/global.css'

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Ricky Estudio VIP — Barbería premium en Honduras. Experiencia, estilo y clase. Agenda tu cita online." />
    <meta name="theme-color" content="#070707" />
    
    <!-- Meta SEO -->
    <meta property="og:title" content="The Ricky Estudio VIP | Barbería Premium" />
    <meta property="og:description" content="Experiencia, estilo y clase. Tu barbería premium." />
    <meta property="og:type" content="website" />
    
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    
    <!-- Preconnect & Font Optimization -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap&font-display=swap" rel="stylesheet" />
    
    <title>{title}</title>

    <style is:global>
      /* Prevent CLS on fonts */
      body { font-family: 'Outfit', sans-serif; }
    </style>
  </head>
  <body class="bg-dark text-white selection:bg-gold selection:text-black">
    <slot />
  </body>
</html>
