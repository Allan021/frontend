---
import '../styles/global.css'

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Ricky Estudio VIP — Barbería premium en Honduras. Experiencia, estilo y clase. Agenda tu cita online." />
    <meta name="theme-color" content="#070707" />
    
    <!-- Meta SEO -->
    <meta property="og:title" content="The Ricky Estudio VIP | Barbería Premium" />
    <meta property="og:description" content="Experiencia, estilo y clase. Tu barbería premium." />
    <meta property="og:type" content="website" />
    
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    
    <!-- Font: Preload critical weight, load rest async -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;900&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;900&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap" /></noscript>
    
    <title>{title}</title>

    <style is:global>
      /* Fallback font-stack while Outfit loads */
      body { font-family: 'Outfit', system-ui, -apple-system, 'Segoe UI', sans-serif; }
      /* Reduce CLS: reserve space for known layout elements */
      .hero-section { min-height: 95vh; contain: layout; }
    </style>
  </head>
  <body class="bg-dark text-white selection:bg-gold selection:text-black">
    <slot />
  </body>
</html>
